# pipemedic configuration — copy to .env and fill in (never commit .env)
# Load with:  set -a; source .env; set +a

# Anthropic API key: console.anthropic.com -> API Keys
PIPEMEDIC_ANTHROPIC_API_KEY=sk-ant-...

# GitHub fine-grained PAT scoped to your dbt project repo
# (Contents: read/write, Pull requests: read/write)
PIPEMEDIC_GITHUB_TOKEN=github_pat_...
# The dbt project repo pipemedic opens PRs against, "owner/name"
PIPEMEDIC_GITHUB_REPO=your-org/your-dbt-repo

# Databricks workspace (User Settings -> Developer -> Access tokens;
# warehouse ID from SQL Warehouses -> connection details)
PIPEMEDIC_DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
PIPEMEDIC_DATABRICKS_TOKEN=dapi...
PIPEMEDIC_DATABRICKS_WAREHOUSE_ID=...

# Optional (defaults shown). The validator exports PIPEMEDIC_SCHEMA=<dev_schema>
# during builds; your profiles.yml must template its schema from that var —
# see README "Safety" section.
# PIPEMEDIC_DEV_SCHEMA=pipemedic_dev
# PIPEMEDIC_USE_ICEBERG_BRANCH=true
# PIPEMEDIC_MAX_RETRIES=3
